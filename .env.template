# ================================================
# 무매 크립토 봇 - 환경변수 설정
# 이 파일을 .env 로 저장하고 값을 채우세요
# ================================================

# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_TOKEN=여기에_텔레그램_봇_토큰_입력

# 본인 텔레그램 채팅 ID (보안: 본인만 명령 가능)
# 확인법: 텔레그램에서 @userinfobot 에게 메시지 보내기
CHAT_ID=여기에_본인_채팅ID_입력

# 빗썸 API 키 (빗썸 > 마이페이지 > API 관리)
BITHUMB_API_KEY=여기에_빗썸_API키_입력
BITHUMB_SECRET=여기에_빗썸_시크릿키_입력

# 종목별 시드머니 (원화, 숫자만)
# 예: 500000 = 50만원
SEED_BTC=500000
SEED_ETH=300000
